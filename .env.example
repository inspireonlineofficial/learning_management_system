# .env.example
#
# Copy this file to .env before running `docker compose up`:
#   cp .env.example .env
#
# Then fill in the required values for your local environment.
# Do NOT commit .env to version control — it contains secrets.

# =============================================================================
# Server
# =============================================================================

# HTTP listen port (default: 8080)
SERVER_PORT=8080

# Frontend URL used in password reset and OAuth redirects
FRONTEND_BASE_URL=http://localhost:3000

# =============================================================================
# Database
# =============================================================================

# PostgreSQL username used by the database container
POSTGRES_USER=postgres

# PostgreSQL password used by the database container
POSTGRES_PASSWORD=change_me_strong_password_here

# PostgreSQL database name used by the database container
POSTGRES_DB=lms

# PostgreSQL connection string (required)
# Format: postgres://user:password@host:port/dbname?sslmode=disable
DATABASE_DSN=postgres://postgres:change_me_strong_password_here@postgres:5432/lms?sslmode=disable

# =============================================================================
# Redis
# =============================================================================

# Redis password used by the container
REDIS_PASSWORD=change_me_strong_redis_password

# Redis connection URL (required)
REDIS_URL=redis://:change_me_strong_redis_password@redis:6379

# =============================================================================
# RustFS / S3-compatible Object Storage
# =============================================================================

# RustFS/MinIO endpoint (required)
RUSTFS_ENDPOINT=http://rustfs:9000

# RustFS access key (required)
RUSTFS_ACCESS_KEY=change_me_access_key

# RustFS secret key (required)
RUSTFS_SECRET_KEY=change_me_secret_key_min_32_chars

# RustFS region (default: us-east-1)
RUSTFS_REGION=us-east-1

# Bucket names (defaults shown)
RUSTFS_VIDEO_BUCKET=lms-videos
RUSTFS_FILES_BUCKET=lms-files
RUSTFS_CERTIFICATES_BUCKET=lms-certificates
RUSTFS_BOOKS_BUCKET=lms-books

# =============================================================================
# JWT
# =============================================================================

# Path to RSA private key file inside the container (required)
# The ./keys/ directory is bind-mounted into the container at runtime.
JWT_PRIVATE_KEY_PATH=/app/keys/private.pem

# Path to RSA public key file inside the container (required)
JWT_PUBLIC_KEY_PATH=/app/keys/public.pem

# JWT issuer claim (default: lms-backend)
JWT_ISSUER=lms-backend

# =============================================================================
# SMTP
# =============================================================================

# SMTP server host (required)
SMTP_HOST=smtp.example.com

# SMTP server port (default: 587)
SMTP_PORT=587

# SMTP credentials (required)
SMTP_USERNAME=your_smtp_username_here
SMTP_PASSWORD=your_smtp_password_here

# From address used in outgoing emails (required)
SMTP_FROM=no-reply@example.com

# Admin development bypass for local testing only
ADMIN_DEV_BYPASS=false
ADMIN_DEV_OTP=000000

# =============================================================================
# OAuth Providers (optional — leave blank to disable)
# =============================================================================

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URL=

# Microsoft OAuth
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URL=

# =============================================================================
# Typesense
# =============================================================================

# Typesense server host (default: typesense)
TYPESENSE_HOST=typesense

# Typesense server port (default: 8108)
TYPESENSE_PORT=8108

# Typesense API key (required)
TYPESENSE_API_KEY=change_me_typesense_api_key

# =============================================================================
# Frontend
# =============================================================================

# Frontend API base URL used when building the frontend
VITE_API_BASE_URL=http://localhost:8080

# =============================================================================
# bKash Payment Gateway
# =============================================================================

# bKash tokenized checkout base URL
# Sandbox: https://tokenized.sandbox.bka.sh/v1.2.0-beta
# Production: https://tokenized.pay.bka.sh/v1.2.0-beta
BKASH_BASE_URL=https://tokenized.sandbox.bka.sh/v1.2.0-beta

# bKash application key — issued by bKash for your merchant account
BKASH_APP_KEY=sandbox_app_key_abc123xyz

# bKash application secret — paired with the app key above
BKASH_APP_SECRET=sandbox_app_secret_def456uvw

# bKash merchant username — used to obtain the auth token
BKASH_USERNAME=sandbox_merchant_user

# bKash merchant password — used to obtain the auth token
BKASH_PASSWORD=sandbox_merchant_pass

# Callback URL bKash redirects to after the customer completes payment
# Must be publicly reachable; use ngrok or similar for local development
BKASH_CALLBACK_URL=http://localhost:8080/v1/payments/bkash/callback
