# .env.example
#
# Copy this file to .env before running:
#   cp .env.example .env
#
# Then fill in the required values for your production environment.
# Do NOT commit .env to version control — it contains secrets.

# =============================================================================
# Server
# =============================================================================

# HTTP listen port (default: 8080)
SERVER_PORT=8080

# Frontend URL used in password reset and OAuth redirects
FRONTEND_BASE_URL=http://localhost:3000

# =============================================================================
# Database (Running in Docker)
# =============================================================================

# PostgreSQL username
POSTGRES_USER=postgres

# PostgreSQL password
POSTGRES_PASSWORD=change_me_strong_password_here

# PostgreSQL database name
POSTGRES_DB=lms

# PostgreSQL connection string pointing to internal docker network host (postgres)
# Format: postgres://user:password@host:port/dbname?sslmode=disable
DATABASE_DSN=postgres://postgres:change_me_strong_password_here@postgres:5432/lms?sslmode=disable

# =============================================================================
# Redis
# =============================================================================

# Redis password
REDIS_PASSWORD=rEd1S_S3cur3_Pa$$w0rd_2026

# Redis connection URL (running in docker)
REDIS_URL=redis://:rEd1S_S3cur3_Pa$$w0rd_2026@redis:6379

# =============================================================================
# Object Storage (DigitalOcean Spaces / S3-compatible)
# =============================================================================

# DigitalOcean Spaces endpoint (required)
RUSTFS_ENDPOINT=https://inspirelms.sgp1.digitaloceanspaces.com

# DigitalOcean Spaces access key (required)
RUSTFS_ACCESS_KEY=your_digitalocean_spaces_access_key_here

# DigitalOcean Spaces secret key (required)
RUSTFS_SECRET_KEY=your_digitalocean_spaces_secret_key_here

# DigitalOcean Spaces region (e.g., sgp1)
RUSTFS_REGION=sgp1

# Bucket names
RUSTFS_VIDEO_BUCKET=inspirelms
RUSTFS_FILES_BUCKET=inspirelms
RUSTFS_CERTIFICATES_BUCKET=inspirelms
RUSTFS_BOOKS_BUCKET=inspirelms

# =============================================================================
# JWT
# =============================================================================

# Path to RSA private key file inside the container/application (required)
JWT_PRIVATE_KEY_PATH=keys/private.pem

# Path to RSA public key file inside the container/application (required)
JWT_PUBLIC_KEY_PATH=keys/public.pem

# JWT issuer claim (default: lms-backend)
JWT_ISSUER=lms-backend

# =============================================================================
# SMTP (To be setup later)
# =============================================================================

# SMTP server host
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@example.com

# Admin development bypass for local testing only
ADMIN_DEV_BYPASS=false
ADMIN_DEV_OTP=000000

# =============================================================================
# OAuth Providers (Google OAuth to be setup later)
# =============================================================================

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=

# =============================================================================
# Typesense
# =============================================================================

# Typesense server host (running in docker)
TYPESENSE_HOST=typesense

# Typesense server port (default: 8108)
TYPESENSE_PORT=8108

# Typesense API key (required)
TYPESENSE_API_KEY=change_me_typesense_api_key

# =============================================================================
# Frontend
# =============================================================================

# Frontend API base URL used when building the frontend
VITE_API_BASE_URL=http://localhost:8080
